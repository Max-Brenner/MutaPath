// Output publish directories for each process
// All paths relative to params.outdir (defined in nextflow.conf)

process {

    // Input Layer
    withName: 'INPUT_PARSER' {
        publishDir = [
            path: "${params.outdir}/input",
            mode: 'copy'
        ]
    }

    withName: 'VARIANT_SELECTOR' {
        publishDir = [
            path: "${params.outdir}/input",
            mode: 'copy'
        ]
    }

    // Annotation Layer
    withName: 'CONSEQUENCE_ANNOTATOR' {
        publishDir = [
            path: "${params.outdir}/annotation",
            mode: 'copy'
        ]
    }

    withName: 'REGULATORY_EFFECTS' {
        publishDir = [
            path: "${params.outdir}/annotation",
            mode: 'copy'
        ]
    }

    // Protein Layer
    withName: 'PROTEIN_EFFECTS' {
        publishDir = [
            path: "${params.outdir}/protein",
            mode: 'copy'
        ]
    }

    withName: 'STRUCTURE_EFFECTS' {
        publishDir = [
            path: "${params.outdir}/protein",
            mode: 'copy'
        ]
    }

    // Biological Context Layer
    withName: 'PATHWAY_MAPPER' {
        publishDir = [
            path: "${params.outdir}/context",
            mode: 'copy'
        ]
    }

    withName: 'METABOLIC_IMPACT_ENGINE' {
        publishDir = [
            path: "${params.outdir}/context",
            mode: 'copy'
        ]
    }

    // Integration Layer
    withName: 'EVIDENCE_SCHEMA' {
        publishDir = [
            path: "${params.outdir}/evidence",
            mode: 'copy'
        ]
    }

    // AI Layer
    withName: 'AI_REASONER' {
        publishDir = [
            path: "${params.outdir}/ai",
            mode: 'copy'
        ]
    }

    withName: 'HYPOTHESIS_RANKER' {
        publishDir = [
            path: "${params.outdir}/ai",
            mode: 'copy'
        ]
    }

    // Output Layer
    withName: 'REPORT_GENERATOR' {
        publishDir = [
            path: "${params.outdir}/reports",
            mode: 'copy'
        ]
    }

    withName: 'VISUALIZATION' {
        publishDir = [
            path: "${params.outdir}/reports",
            mode: 'copy'
        ]
    }

}
